class Solution:
    def reverseOnlyLetters(self, s: str) -> str:
        a=list(s)
        i=0
        j=len(s)-1
        while(i<=j):
            if a[i].isalpha() and a[j].isalpha():
                a[i],a[j]=a[j],a[i]
                i=i+1
                j=j-1
            elif not a[i].isalpha():
                i=i+1
            elif not a[j].isalpha():
                j=j-1
        t="".join(a)
        return t
